# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=sistema_municipal

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura_cambiala_en_produccion
