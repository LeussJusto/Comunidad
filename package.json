{
  "name": "sistema-municipal-backend",
  "version": "1.0.0",
  "description": "Sistema Municipal - Backend API REST",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "db:migrate": "ts-node src/infrastructure/database/migrations/run-migrations.ts",
    "db:seed": "ts-node src/infrastructure/database/seeds/run-seeds.ts",
    "seed:users": "ts-node -r tsconfig-paths/register src/infrastructure/database/seeds/seed-users.ts",
    "uploads:clean": "ts-node scripts/clean-uploads.ts",
    "uploads:check": "ts-node scripts/check-uploads.ts"
  },
  "keywords": [
    "municipal",
    "api",
    "ddd",
    "clean-architecture"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/pdfkit": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.6.1",
    "typeorm": "^0.3.19",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/socket.io": "^3.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.3"
  }
}
